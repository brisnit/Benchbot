# ─────────────────────────────────────────────────────────────
# BenchBot environment variables
# Copy to `.env.local` and fill in. The app runs in DEMO mode with
# none of these set — every variable below is optional for local review.
# ─────────────────────────────────────────────────────────────

# --- Supabase (database / auth / storage) ---
# When unset, BenchBot uses an in-memory + file-backed local store and a
# cookie-based mock auth so the full flow works without any backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI competitor discovery + audit analysis) ---
# When unset, BenchBot generates deterministic, clearly-labelled
# "AI-estimated" mock analysis so the UI is fully reviewable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Crawling ---
# When false (default in demo), no real network crawling is performed and
# realistic placeholder crawl data + screenshots are generated instead.
ENABLE_REAL_CRAWL=false

# --- Demo mode ---
# When true, a fully-populated sample audit is seeded for every workspace.
DEMO_MODE=true

# --- Stripe (billing — stubbed for MVP) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
